# ─────────────────────────────────────────────────────────────────────────────
# SourcingOS — environment variables (next-public/)
# Copy to .env.local for development. NEVER commit real values.
#
# Vercel setup: add Production values in Project → Settings → Environment
# Variables. Audit Preview environment separately — preview deployments must
# NOT carry paid provider keys unless they also carry full auth config.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site identity (required for correct OG/canonical/sitemap URLs) ───────────
NEXT_PUBLIC_SITE_URL=https://your-production-domain.example

# ── Supabase (required for auth + durable persistence) ───────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key. Server-only. Bypasses RLS — handle with extreme care.
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth behavior ─────────────────────────────────────────────────────────────
# FAIL-CLOSED default: when Supabase is unconfigured, protected routes return
# 503. Set to 'true' ONLY for local dev or access-protected preview deploys
# that carry NO paid provider keys.
ALLOW_PREVIEW_BYPASS=false

# ── Rate limiting (strongly recommended in production) ────────────────────────
# Upstash Redis REST credentials (Vercel Marketplace → Upstash).
# Without these, limits fall back to per-instance in-memory (best effort only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Set to 'true' only in automated tests.
# RATE_LIMIT_DISABLED=false

# ── AI provider (server-only; never exposed to the browser) ──────────────────
ANTHROPIC_API_KEY=
# Optional generic alias + model override.
# AI_PROVIDER_API_KEY=
# AI_PROVIDER_MODEL=

# ── Contact enrichment (paid, per-lookup — keep behind auth + limits) ─────────
PEOPLE_DATA_LABS_API_KEY=

# ── Jobs ingestion (optional public sources) ──────────────────────────────────
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=

# ── Scheduled refresh ─────────────────────────────────────────────────────────
# REQUIRED for /api/candidates/cron-refresh — the route returns 503 without it.
CRON_SECRET=

# ── Demo data (keep false in production) ──────────────────────────────────────
NEXT_PUBLIC_ENABLE_DEMO_SOURCE_RESULTS=false
